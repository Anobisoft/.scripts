# shellcheck shell=bash
# ==============================================================================
# === Anobisoft Terminal Aliases & Shortcuts                                ===
# ==============================================================================

# --- 1. Системное администрирование (Nginx) ---
# Проверка конфигурации и мягкий перезапуск веб-сервера без прерывания соединений
alias nginx_reload='sudo nginx -t && sudo systemctl reload nginx'

# --- 2. Цветовое оформление и кастомизация вывода ---
# Включаем нативную подсветку совпадений для утилит поиска и сравнения
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias diff='diff --color=auto'

# Форматирование списков директорий: цвета, первыми идут папки, скрываем имя группы (-G)
alias ls='ls --color=auto --group-directories-first -G'

# --- 3. Очистка кэша и оптимизация Xcode ---
# Удаление временных файлов сборки проектов (DerivedData)
alias xclear_deriveddata='rm -rf ~/Library/Developer/Xcode/DerivedData/'

# Очистка внутреннего кэша компилятора Clang
alias xclear_clang_cache='rm -rf "$(getconf DARWIN_USER_CACHE_DIR)/org.llvm.clang/ModuleCache"'

# Очистка системного кэша самого приложения Xcode
alias xclear_cache='rm -rf ~/Library/Caches/com.apple.dt.Xcode'

# Полная комплексная очистка всего кэша разработки Xcode одной командой
alias xclear='xclear_deriveddata && xclear_cache && xclear_clang_cache'

# Жесткое завершение всех зависших процессов Xcode и его симуляторов.
# Написано через ручной сбор PID-ов на случай, если не сработал pkill -9 -i -f "xcode"
# (помогает выковыривать и прибивать «зомби-процессы», блокирующие перезапуск Xcode).
alias killxcode='ps ax | grep -i xcode | grep -v grep | awk "{ print \$1; }" | tr "\n" " " | xargs kill -9'
