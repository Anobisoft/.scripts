# shellcheck shell=bash
# ==============================================================================
# === Anobisoft Terminal Utility Functions                                   ===
# ==============================================================================

# ------------------------------------------------------------------------------
# Функция: hlstderr (Highlight STDERR in Red)
# Описание: Обертка для любой команды, которая перехватывает поток ошибок STDERR,
#           очищает его от префиксов номеров строк и окрашивает в ярко-красный цвет.
# Использование: hlstderr команда --флаги аргументы
# TODO: Понаблюдать эффект буфера при долгой работе команд (возможна задержка
#       вывода строк из-за блочной буферизации конвейера 'while read').
# ------------------------------------------------------------------------------
function hlstderr() {
    # Включаем pipefail локально внутри функции, чтобы статус возврата ($?)
    # отражал код ошибки исходной команды, а не успешный цикл 'while read'
    setopt localoptions pipefail

    # Карусель дескрипторов:
    # 1. 3>&1  — создаем дескриптор 3 и направляем его туда, куда смотрел STDOUT (на экран)
    # 2. 1>&2  — перенаправляем STDOUT в поток STDERR
    # 3. 2>&3  — перенаправляем STDERR в дескриптор 3 (то есть на экран)
    # 4. 3>&2  — возвращаем дескриптор 3 обратно в STDERR для пайпа
    # В итоге: STDOUT идет на экран напрямую, а чистый STDERR уходит в конвейер '|'
    "$@" 3>&1 1>&2 2>&3 3>&2 | while read -r line
    do
        # Регулярный Zsh-модификатор: срезает служебные префиксы ошибок вида "filename: line XX:"
        local clean_line="${line##*:[0-9]#: }"

        # Выводим строку в терминал, окрашивая её в красный цвет через встроенный движок %F/%f
        print -P "%F{red}${clean_line}%f"
    done
}
