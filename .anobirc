# shellcheck shell=bash disable=SC1091,SC2206,SC2128,SC2154,SC2034
# ==============================================================================
# === Anobisoft Zsh Core Runcom (.anobirc)                                   ===
# ==============================================================================

# shellcheck disable=SC2168
# Динамически вычисляем абсолютный путь к папке, в которой физически лежит текущий файл .anobirc.
# Это гарантирует корректную работу всех source-запросов, даже если репозиторий был перемещен или
# установлен по кастомному пути в начале развертывания окружения.
local _ANOBI_CORE="${0:A:h}"

# --- 1. Системные настройки терминала и путей ---
# Устанавливаем аппаратную ширину табуляции в терминале равной 4 пробелам
tabs -4

# Включаем строгую автоматическую дедупликацию путей для массивов path и PATH в Zsh.
# Защищает систему от дублирования путей при многократных инициализациях шелла.
typeset -U path PATH

# --- 2. Подключение внешних конфигурационных модулей Anobisoft ---
# Инициализация динамического реактивного промпт-движка (часы и Git)
source "$_ANOBI_CORE/.prompt"

# Загрузка кастомных системных алиасов и сокращений
source "$_ANOBI_CORE/.alias"

# Загрузка заготовок HTTP-заголовков и шаблонов таймингов для утилиты cURL
source "$_ANOBI_CORE/.curl_templates"

# --- 3. Глобальные переменные окружения утилит GNU ---
# Задаем единый международный ISO-формат вывода даты и времени для утилит ls и find (ГГГГ-ММ-ДД ЧЧ:ММ)
export TIME_STYLE="long-iso"

# --- 4. Интеграция автодополнения для Git (fpath) ---
# Настройка путей автодополнения в зависимости от операционной системы (Linux или macOS с Homebrew)
if [ -d "/usr/share/zsh/functions/Completion/Unix" ]; then
    fpath=(/usr/share/zsh/functions/Completion/Unix $fpath)
elif (( $+commands[brew] )) && [ -d "$(brew --prefix)/share/zsh/site-functions" ]; then
    fpath=("$(brew --prefix)"/share/zsh/site-functions $fpath)
fi

# Принудительно загружаем функцию автодополнения команд Git
autoload -Uz _git

# --- 5. Подключение внешних плагинов подсветки и автопредложений ---
# Инициализация плагина автодополнения команд на основе истории ввода (zsh-autosuggestions)
if [ -f "$HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source "$HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# Инициализация плагина интерактивной подсветки синтаксиса в командной строке (zsh-syntax-highlighting)
if [ -f "$HOME/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source "$HOME/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
