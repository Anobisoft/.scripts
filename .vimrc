syntax on
set tabstop=4 shiftwidth=4 expandtab smarttab
set nocompatible
set backspace=indent,eol,start
set ai

set hlsearch        " Подсвечивает совпадения при поиске через '/'
set wildmenu        " Включает удобное графическое автодополнение команд внизу экрана
set ruler           " Показывает текущую строку и колонку в правом нижнем углу
