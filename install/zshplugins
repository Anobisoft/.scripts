#!/bin/bash
# ==============================================================================
# === Anobisoft Environment: Zsh Plugins Standalone Installer               ===
# ==============================================================================

# Динамически берем базовый URL организации GitHub из первого аргумента,
# либо используем официальный адрес по умолчанию.
readonly URL_ZSH_PLUGINS_BASE="${1:-'https://github.com/zsh-users/'}"

# Создаем скрытую локальную папку для хранения расширений Zsh, если она отсутствует
ZSH_PLUGINS="$HOME/.zsh/plugins"
mkdir -p "$ZSH_PLUGINS"

# --- 1. Функция управления жизненным циклом плагинов ---
# Описание: Автоматически клонирует репозиторий плагина с GitHub, используя базовую
#           константу URL, либо обновляет его до актуального состояния через git pull.
install_or_update_plugin() {
    local plugin_name=$1
    # Склеиваем базовый путь организации GitHub и имя конкретного плагина
    local plugin_url="${URL_ZSH_PLUGINS_BASE}$1.git"
    local target_dir="$ZSH_PLUGINS/$plugin_name"

    if [ ! -d "$target_dir" ]; then
        echo "Installing plugin: $plugin_name..."
        git clone "$plugin_url" "$target_dir"
    else
        echo "Plugin $plugin_name is already installed. Updating..."
        # Переходим в директорию плагина в subshell, чтобы не менять рабочий каталог инсталлятора
        (cd "$target_dir" && git pull)
    fi
}

# --- 2. Развертывание целевых зависимостей окружения ---
# Скачиваем/обновляем плагины автодополнения на основе истории и интерактивной подсветки синтаксиса
install_or_update_plugin "zsh-autosuggestions"
install_or_update_plugin "zsh-syntax-highlighting"

echo "🎉 zsh plugins successfully prepared!"
