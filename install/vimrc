#!/bin/bash
# ==============================================================================
# === Anobisoft Environment: Vim Configuration Deployer                     ===
# ==============================================================================

# Разрешаем экстренное завершение скрипта при ошибках
set -e

# Вычисляем относительный путь к директории текущего скрипта
SCRIPT_DIR=$(dirname "$0")

# Указываем путь к исходному файлу .vimrc на один уровень выше (в корне репозитория)
VIMRC_SOURCE="$SCRIPT_DIR/../.vimrc"

# --- 1. Проверка наличия исходного файла конфигурации ---
if [ ! -f "$VIMRC_SOURCE" ]; then
    echo "No .vimrc found in repo, skipping."
    exit 0
fi

# --- 2. Деплой конфигурации пользователю ---
echo "Deploying Vim configuration..."
cp "$VIMRC_SOURCE" "$HOME"

# --- 3. Деплой конфигурации для суперпользователя (root) ---
# Временно отключаем 'set -e', чтобы сбой или отмена sudo не роняли инсталлятор
set +e

# Копирование в root-директорию с флагом -H для гарантированного раскрытия $HOME как /var/root
sudo -H sh -c "cp '$VIMRC_SOURCE' \$HOME"

# Возвращаем строгий режим обработки ошибок
set -e
