# ==============================================================================
# === Anobisoft Zsh Reactive Prompt Configuration                            ===
# ==============================================================================

# --- 1. Реализация часов реального времени (Real-time Clock) ---
# Задаем интервал системного таймера Zsh в 1 секунду
TMOUT=1

# Ловушка сигнала ALRM: срабатывает каждую секунду по таймеру TMOUT.
# Принудительно заставляет Zsh Line Editor (ZLE) перерисовывать промпт,
# благодаря чему время и статус Git обновляются в реальном времени, пока вы пишете.
TRAPALRM() {
    zle reset-prompt
}

# Включаем режим PROMPT_SUBST — динамическое вычисление переменных, функций
# и подстановок прямо внутри строки приглашения при каждой перерисовке.
setopt PROMPT_SUBST

# --- 2. Определение контекста SSH-сессии ---
# Если терминал запущен удаленно через SSH, формируем префикс "user@host"
if [ -n "$SSH_CONNECTION" ]; then
    SSH_HOST='%F{087}%n%f@%F{cyan}%m '
else
    SSH_HOST=''
fi

# Дефолтный вид промпта для обычных папок (Дата Время Папка Статус_Пользователя)
PROMPT_DEFAULT="$SSH_HOST%F{green}%D{%Y-%m-%d} %F{084}%T %F{blue}%1~ %F{red}%#%f "

# --- 3. Интеграция и тонкая настройка VCS_INFO (Git) ---
# Загружаем встроенную подсистему Zsh для сбора информации о системах контроля версий
autoload -Uz vcs_info

# Включаем проверку наличия измененных файлов в репозитории (unstaged/staged)
zstyle ':vcs_info:git:*' check-for-changes true
# Включаем извлечение хэша текущего коммита (ревизии)
zstyle ':vcs_info:git:*' get-revision true
# Маркеры состояния репозитория: красный '*' для измененных, желтый '+' для добавленных в индекс
zstyle ':vcs_info:git:*' unstagedstr '%F{red}*%f'
zstyle ':vcs_info:git:*' stagedstr '%F{yellow}+%f'

# Шаблон вывода Git в обычном состоянии: Имя_репо/Текущая_папка Ветка [7_символов_SHA] Статус
zstyle ':vcs_info:git:*' formats "%F{red}%r%f/%F{blue}%S%f %F{green}%b %f[%F{yellow}%7.7i%f]%u%c%f"
# Шаблон вывода Git во время интерактивных действий (например, при конфликтах merge/rebase)
zstyle ':vcs_info:git:*' actionformats "%F{red}%r%f/%F{blue}%S%f %F{green}%b %f[%F{yellow}%7.7i%f]%u%c%f %F{red}%a%f"

# --- 4. Функция динамического переключения разметки экрана ---
set_dynamic_prompts() {
    # Собираем актуальные данные о Git в текущей директории
    vcs_info

    # Если мы находимся внутри Git-репозитория ($vcs_info_msg_0_ не пустой):
    if [ -n "$vcs_info_msg_0_" ]; then
        # Перестраиваем основной промпт: убираем дату/время, ставим иконку ветки  и статус Git
        PROMPT="$SSH_HOST%F{cyan}%f ${vcs_info_msg_0_} %f> "
        # Переносим дату и тикающие часы на правый край терминала (RPROMPT)
        RPROMPT="%F{green}%D{%Y-%m-%d} %F{084}%T"
    else
        # Если это обычная папка — возвращаем классический левосторонний промпт, очищая правый
        PROMPT="$PROMPT_DEFAULT"
        RPROMPT=""
    fi
}

# Регистрируем функцию в системный массив Zsh precmd_functions.
# Она гарантированно выполняется перед каждым выводом новой строки приглашения.
precmd_functions+=(set_dynamic_prompts)
