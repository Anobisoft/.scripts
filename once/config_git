#!/bin/bash
# ==============================================================================
# === Anobisoft Global Git Configuration Setup                               ===
# ==============================================================================

echo "Applying global Git configurations..."

# --- 1. Безопасность и инициализация ---
# Принудительно заставляем Git использовать только параметры из файлов конфигурации (.gitconfig),
# игнорируя случайные или подмененные переменные окружения (user.name / user.email)
git config --global user.useConfigOnly true

# Задаем имя ветки по умолчанию 'main' вместо устаревшего 'master' при создании новых репозиториев (git init)
git config --global init.defaultBranch main

# --- 2. Интерфейс и отображение вывода ---
# Настройка утилиты постраничного вывода (пейджера) для команд Git:
# -F — автоматически закрывает less, если весь текст помещается на одном экране
# -X — сохраняет вывод команды на экране терминала после закрытия less (не очищает экран)
git config --global core.pager "less -F -X"

# Отключаем экранирование путей. Позволяет Git корректно, в виде человеческого текста,
# отображать в терминале имена файлов и папок, содержащие не-ASCII символы (например, кириллицу)
git config --global core.quotepath false

# --- 3. Поведение при синхронизации веток ---
# Задаем стандартное поведение для 'git pull' через классический 'merge' (слияние) вместо 'rebase'.
# Это защищает от случайного переписывания локальной истории коммитов при обновлении веток
git config --global pull.rebase false

echo "🎉 Global Git configurations successfully updated!"
